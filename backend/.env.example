# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.

# Database
# Local development uses SQLite (leave DATABASE_URL blank or use the default).
# Production (Railway) will inject a real Postgres URL into this variable.
DATABASE_URL=sqlite:///./garabyte_local.db

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed frontend origins
# For local dev, the Next.js dev server runs on port 3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
