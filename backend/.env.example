# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.

# Database
# Local development uses SQLite (leave DATABASE_URL blank or use the default).
# Production (Railway) will inject a real Postgres URL into this variable.
DATABASE_URL=sqlite:///./garabyte_local.db

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed frontend origins
# For local dev, the Next.js dev server runs on port 3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend base URL — embedded into outbound email links
FRONTEND_BASE_URL=http://localhost:3000

# Email transport
#   stdout  — print to uvicorn terminal (dev default)
#   smtp    — connect to SMTP_HOST:SMTP_PORT with STARTTLS and send for real
EMAIL_BACKEND=stdout

# SMTP credentials (only used when EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=true

# Visible From / Reply-To headers
EMAIL_FROM=Garabyte Privacy <no-reply@garabyte.example>
EMAIL_REPLY_TO=

# Evidence file storage (local-disk by default; swap for object storage in prod)
EVIDENCE_STORAGE_DIR=./evidence_files
EVIDENCE_MAX_BYTES=10485760
